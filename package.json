{
  "name": "unplugin-raw",
  "type": "module",
  "version": "0.7.0",
  "packageManager": "pnpm@10.33.0",
  "description": "Transform file to a default-export string.",
  "author": "Kevin Deng <sxzz@sxzz.moe>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/sxzz",
  "homepage": "https://github.com/unplugin/unplugin-raw#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unplugin/unplugin-raw.git"
  },
  "bugs": {
    "url": "https://github.com/unplugin/unplugin-raw/issues"
  },
  "keywords": [
    "unplugin",
    "rollup",
    "vite",
    "esbuild",
    "webpack"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./api": "./dist/api.mjs",
    "./esbuild": "./dist/esbuild.mjs",
    "./rolldown": "./dist/rolldown.mjs",
    "./rollup": "./dist/rollup.mjs",
    "./rspack": "./dist/rspack.mjs",
    "./vite": "./dist/vite.mjs",
    "./webpack": "./dist/webpack.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsgo --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "esbuild": ">=0.25.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    }
  },
  "dependencies": {
    "unplugin": "^3.0.0",
    "unplugin-utils": "^0.3.1"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "^7.8.4",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "rolldown": "^1.0.0-rc.12",
    "rollup": "^4.60.0",
    "tsdown": "^0.21.7",
    "tsdown-preset-sxzz": "^0.5.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "prettier": "@sxzz/prettier-config"
}
